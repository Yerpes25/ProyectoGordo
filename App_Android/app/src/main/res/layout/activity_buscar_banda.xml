<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#FFFFFF"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Unirse a una Banda"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="16dp"
        android:textAlignment="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Introduce el CIF proporcionado por la directiva de tu agrupación musical para solicitar el acceso."
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp"
        android:textAlignment="center" />

    <EditText
        android:id="@+id/cajaTextoBuscadorCif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ejemplo: G12345678"
        android:inputType="text"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/botonBuscarCif"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="BUSCAR BANDA"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>