<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="panelPrincipal" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appbandas.proyectobanda.vistas.principal.DashboardControlador">
   
   <left>
      <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: #0D47A1;" BorderPane.alignment="CENTER">
         <children>
            <Label text="Proyecto Banda" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="30.0" />
               </VBox.margin>
            </Label>
            
            <Button alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="👥  Gestión de Músicos">
               <font><Font size="16.0" /></font>
            </Button>
            <Button alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="🎺  Inventario">
               <font><Font size="16.0" /></font>
            </Button>
            <Button alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="📅  Eventos y Ensayos">
               <font><Font size="16.0" /></font>
            </Button>
            
            <VBox VBox.vgrow="ALWAYS" /> 
            
            <Button alignment="BASELINE_LEFT" onAction="#manejarCerrarSesion" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white; -fx-cursor: hand;" text="🚪  Cerrar Sesión">
               <font><Font name="System Bold" size="16.0" /></font>
            </Button>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
         </padding>
      </VBox>
   </left>
   
   <center>
      <VBox alignment="CENTER" style="-fx-background-color: #F5F5F5;" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="textoBienvenida" text="Cargando panel..." textFill="#333333">
               <font>
                  <Font size="28.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </center>
</BorderPane>