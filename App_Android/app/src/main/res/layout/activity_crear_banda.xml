<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registrar Nueva Banda"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="24dp"
        android:textAlignment="center" />

    <EditText
        android:id="@+id/cajaTextoNombreBanda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de la Agrupación"
        android:inputType="textPersonName"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/cajaTextoCif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="CIF de la Banda"
        android:inputType="text"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/cajaTextoColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Color Corporativo (Ej: #0D47A1)"
        android:inputType="text"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Precio de alta del servicio: 49,99 €"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#D32F2F"
        android:textAlignment="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/botonPagarRegistrar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="PAGAR Y REGISTRAR"
        android:backgroundTint="#0D47A1"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>