<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Bienvenido a AppBandas!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="La plataforma definitiva para gestionar tu agrupación musical."
        android:textSize="16sp"
        android:textColor="#666666"
        android:textAlignment="center"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/botonCrearBanda"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="CREAR MI BANDA"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#0D47A1"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/botonTengoBanda"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="YA TENGO BANDA"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF" />

</LinearLayout>